[Event/applicationcrash]
Action=Popup|Sound
Sound=dialog-error

[Event/cancellogout]
Action=Popup|Sound
Sound=dialog-information

[Event/exitkde]
Action=Sound
Sound=desktop-logout-long

[Event/notification]
Action=Popup|Sound
Sound=bell

[Event/plasmoidDeleted]
Action=Popup|Sound
Sound=trash-empty

[Event/plasmoidInstallationFailed]
Action=Popup|Sound
Sound=bell

[Event/startkde]
Action=Sound
Sound=desktop-login-long
